# MCPWorks Self-Hosted Configuration
# Copy this file to .env and fill in the values below.

# === REQUIRED ===

# Database (the bundled PostgreSQL container uses these credentials)
DATABASE_URL=postgresql+asyncpg://mcpworks:mcpworks_selfhost@postgres:5432/mcpworks

# Redis
REDIS_URL=redis://redis:6379/0

# JWT signing keys (generate with: openssl ecparam -genkey -name prime256v1 -noout -out keys/private.pem)
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# Envelope encryption key (generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEK_B64=

# Your domain (used for URL generation; not required for local installs)
BASE_DOMAIN=example.com
BASE_SCHEME=https

# Routing mode: "path" (default, recommended), "subdomain" (legacy), "both" (transition)
ROUTING_MODE=path

# ACME email for Let's Encrypt certificate notifications (used by Caddy)
ACME_EMAIL=admin@example.com

# === RECOMMENDED ===

# Allow new user registration
ALLOW_REGISTRATION=true

# Application
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO

# CORS (comma-separated origins, or ["*"] for development)
CORS_ORIGINS=["https://example.com"]

# Admin emails (comma-separated, for admin API access)
ADMIN_EMAILS=["admin@example.com"]

# === OPTIONAL ===

# Email - SMTP (for welcome emails, password resets)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_TLS=true

# Stripe (for paid subscriptions — not needed for self-hosted community use)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (error tracking)
# SENTRY_DSN=
