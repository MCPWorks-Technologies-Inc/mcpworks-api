/* Seccomp DENYLIST for Python 3.11 sandbox (glibc 2.41 / Debian Trixie)
 *
 * Strategy: DEFAULT ALLOW with explicit DENY of dangerous syscalls.
 *
 * nsjail already provides primary isolation via namespaces, cgroups, UID
 * mapping, and chroot.  Seccomp is defense-in-depth — it blocks the ~34
 * syscalls that could escalate privileges or escape containment, while
 * allowing everything else through.  This eliminates the compatibility
 * hell of an allowlist (where every glibc update or new native package
 * can introduce unknown syscalls that SIGSYS-kill the process).
 *
 * NOTE: This is a kafel policy file loaded via nsjail's --seccomp_policy.
 * nsjail compiles each seccomp_string independently, so this MUST be a
 * single file.
 *
 * Categories of denied syscalls:
 *   - Kernel manipulation (loading modules, rebooting, swapping)
 *   - Container/namespace escape (setns, unshare, mount, pivot_root)
 *   - Process injection (ptrace, cross-process memory access)
 *   - Hardware/privileged access (ioperm, iopl, modify_ldt)
 *   - Exploit primitives (bpf, userfaultfd, perf_event_open)
 *   - Kernel keyring (add_key, request_key, keyctl)
 *   - Clock manipulation (settimeofday, adjtimex, clock_settime)
 *
 * NOT denied (and why):
 *   - clone/clone3: Python threading needs them; nsjail restricts CLONE_NEW*
 *   - socket/connect: Network control is via iptables (existing architecture)
 *   - prctl: Python signal handling needs it; dangerous ops need CAP_SYS_ADMIN
 *   - execve: nsjail chroot restricts what can be executed
 */

DENY {
  /* ── Kernel manipulation ── */
  kexec_load,         /* Load a new kernel for later execution */
  kexec_file_load,    /* Load a new kernel (file-descriptor variant) */
  reboot,             /* Reboot or enable/disable Ctrl-Alt-Del */
  init_module,        /* Load a kernel module */
  finit_module,       /* Load a kernel module (fd variant) */
  delete_module,      /* Unload a kernel module */
  acct,               /* Toggle process accounting */
  swapon,             /* Start swapping to file/device */
  swapoff,            /* Stop swapping to file/device */
  nfsservctl,         /* NFS server control (obsolete but still a syscall) */

  /* ── Container/namespace escape ── */
  setns,              /* Reassociate thread with a namespace */
  unshare,            /* Disassociate parts of the execution context */
  pivot_root,         /* Change the root mount */
  mount,              /* Mount filesystem */
  umount,             /* Unmount filesystem */
  umount2,            /* Unmount filesystem (flags variant) */
  open_by_handle_at,  /* Open file by handle (container escape vector) */

  /* ── Process injection ── */
  ptrace,             /* Trace/debug another process */
  process_vm_readv,   /* Read from another process's address space */
  process_vm_writev,  /* Write to another process's address space */
  kcmp,               /* Compare two processes (info leak) */

  /* ── Hardware/privileged access ── */
  ioperm,             /* Set port I/O permissions */
  iopl,               /* Change I/O privilege level */
  modify_ldt,         /* Modify local descriptor table */
  lookup_dcookie,     /* Return a directory entry's path (profiling) */

  /* ── Exploit primitives ── */
  bpf,                /* eBPF operations (kernel code execution) */
  userfaultfd,        /* Create userfaultfd (use-after-free primitive) */
  perf_event_open,    /* Performance monitoring (info leak + exploit) */
  personality,        /* Set process execution domain */

  /* ── Kernel keyring ── */
  add_key,            /* Add a key to the kernel keyring */
  request_key,        /* Request a key from the kernel keyring */
  keyctl,             /* Manipulate the kernel keyring */

  /* ── Clock manipulation ── */
  clock_settime,      /* Set a clock (requires CAP_SYS_TIME) */
  settimeofday,       /* Set system time */
  adjtimex,           /* Tune kernel clock */
  clock_adjtime       /* Tune a POSIX clock */
}

DEFAULT ALLOW
