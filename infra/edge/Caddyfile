# MCPWorks Edge Caddyfile — api.mcpworks.io
# This server is a TLS-terminating reverse proxy only.
# All application services run on server0.pop11 (10.100.0.3) via WireGuard.

{
    email admin@mcpworks.io

    on_demand_tls {
        ask http://10.100.0.3:8000/v1/internal/verify-domain
    }
}

# Main API endpoint
api.mcpworks.io {
    reverse_proxy 10.100.0.3:8000 {
        health_uri /v1/health/ready
        health_interval 15s
        health_timeout 5s
    }

    @legal path /v1/legal/*
    @notlegal not path /v1/legal/*
    header @legal X-Frame-Options SAMEORIGIN
    header @notlegal X-Frame-Options DENY

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}

# Namespace Management Interface (*.create.mcpworks.io)
*.create.mcpworks.io {
    tls {
        on_demand
    }

    reverse_proxy 10.100.0.3:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}

# Namespace Execution Interface (*.run.mcpworks.io)
*.run.mcpworks.io {
    tls {
        on_demand
    }

    reverse_proxy 10.100.0.3:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}

# Agent Webhook Interface (*.agent.mcpworks.io)
*.agent.mcpworks.io {
    tls {
        on_demand
    }

    reverse_proxy 10.100.0.3:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}

# GenOps (genops.dev) -> server1.pop11
genops.dev {
    reverse_proxy 10.100.0.4:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}

# Health check (no TLS)
:80 {
    respond /health "OK" 200
}
