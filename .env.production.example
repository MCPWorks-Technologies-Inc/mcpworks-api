# Production Environment Variables
# Copy to .env.production and fill in values
#
# STAGING HOOK: For staging, copy to .env.staging and change:
#   - APP_ENV=staging
#   - APP_DEBUG=true
#   - Use Stripe test keys (sk_test_*, whsec_test_*)
#   - Use staging database URL
#   - Update CORS_ORIGINS for staging domain

# =============================================================================
# Application
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# =============================================================================
# Database (provided by DO App Platform as ${db.DATABASE_URL})
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# =============================================================================
# Redis (provided by DO App Platform as ${redis.DATABASE_URL})
# =============================================================================
# REDIS_URL=redis://host:6379/0

# =============================================================================
# JWT Authentication (ES256 keys)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out private.pem
#                openssl ec -in private.pem -pubout -out public.pem
# =============================================================================
# JWT_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Stripe
# STAGING HOOK: Use sk_test_* and whsec_test_* for staging
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# =============================================================================
# Backend Services
# =============================================================================
MATH_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_URL=http://localhost:8002
# AGENT_CALLBACK_SECRET=your-32-char-minimum-secret-here

# =============================================================================
# Observability
# =============================================================================
PROMETHEUS_ENABLED=true

# =============================================================================
# Security
# STAGING HOOK: Add staging domains for staging environment
# =============================================================================
CORS_ORIGINS=["https://mcpworks.io", "https://www.mcpworks.io", "https://app.mcpworks.io"]
